; M1 asm-vs-reference stress score — exercises the paths ab-core.mmlisp does
; not reach: backward JUMP (#loop / go), extended (>254-tick) durations,
; MASTER and pan changes mid-song, noise mode switching, nested loops at the
; 4-deep control-stack limit, LFO rate changes, and vel/gate extremes.
; Trace-compared over a fixed frame horizon (the song loops forever).

(def stab :alg 7 :fb 2
  :ar1 31 :dr1 8 :sr1 2 :rr1 8 :sl1 3 :tl1 12 :ks1 1 :ml1 1 :dt1 1
  :ar2 30 :dr2 7 :sr2 1 :rr2 7 :sl2 2 :tl2 16 :ks2 0 :ml2 2 :dt2 -1
  :ar3 29 :dr3 6 :sr3 1 :rr3 6 :sl3 2 :tl3 20 :ks3 1 :ml3 3 :dt3 2
  :ar4 31 :dr4 9 :sr4 2 :rr4 9 :sl4 4 :tl4 6 :ks4 0 :ml4 1 :dt4 0)

(score :tempo 132 :lfo-rate 2
  (fm1 stab :oct 4 :len 8 :vel 14
    #loop
    c e g > c1 ~ 2 <
    :vel 4
    (x 2 (x 2 (x 2 (x 2 e16))))
    :vel 15
    :pan left
    f a
    :pan right
    g b
    :pan center
    :master 20
    c2
    :master 31
    (go loop))

  (fm4 stab :oct 2 :len 2 :vel 12
    c < b1 ~ 1 > c4 c4
    :lfo-rate 7
    d1)

  (sqr1 :oct 6 :len 16 :vel 9
    (x 3 c e g e :break c d)
    :gate* 0.25
    a8 g8 f8 e8
    :gate* 1.0
    c1)

  (noise :len 4 :vel 10
    :mode white2
    c c8 c8
    :mode periodic1
    c c
    :mode white0
    c2))
