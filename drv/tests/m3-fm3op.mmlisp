; M3 gate: FM3 independent-operator mode. A shared patch plus four
; per-operator F-number tracks that key their own $28 slot. Exercises the
; special-mode register map ($27 bit6, A8-AE / A2/A6), the shared $28 op
; mask across coexisting ch2/16-18 tracks, mid-stream op key-off (rest),
; and staggered track ends.
(def kit :alg 4 :fb 3
  :ar1 31 :dr1 6 :sr1 1 :rr1 6 :sl1 2 :tl1 24 :ks1 0 :ml1 2 :dt1 0
  :ar2 31 :dr2 8 :sr2 2 :rr2 8 :sl2 2 :tl2 8 :ks2 0 :ml2 1 :dt2 0
  :ar3 31 :dr3 6 :sr3 1 :rr3 6 :sl3 2 :tl3 28 :ks3 0 :ml3 4 :dt3 0
  :ar4 31 :dr4 9 :sr4 2 :rr4 9 :sl4 3 :tl4 4 :ks4 0 :ml4 1 :dt4 0)
(score :tempo 120
  (fm3 kit)
  (fm3-1 :oct 5 :len 4  c e g c)
  (fm3-2 :oct 4 :len 4  e _ c e)
  (fm3-3 :oct 3 :len 2  c g)
  (fm3-4 :oct 4 :len 4  g c e g))
