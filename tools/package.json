{
  "name": "mmlisp-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal local tooling for MMLisp draft workflow",
  "scripts": {
    "format:mmlisp": "node scripts/format-mmlisp.js ../examples/source/*.mmlisp",
    "check:format:mmlisp": "node scripts/format-mmlisp.js --check ../examples/source/*.mmlisp",
    "mmlisp2ir": "node scripts/mmlisp2ir.js",
    "verify-ir": "node scripts/verify-ir.js",
    "mmlisp2mmb": "node scripts/mmlisp2mmb.js",
    "verify-mmb": "node scripts/verify-mmb.js",
    "build:ir-demos": "node scripts/mmlisp2ir.js ../examples/source/demo1-stage-loop.mmlisp --strict --diag-out ../examples/ir/demo1-stage-loop.diagnostics.generated.json --out ../examples/ir/demo1-stage-loop.ir.generated.json && node scripts/mmlisp2ir.js ../examples/source/demo2-event-recovery.mmlisp --strict --diag-out ../examples/ir/demo2-event-recovery.diagnostics.generated.json --out ../examples/ir/demo2-event-recovery.ir.generated.json",
    "check:ir-demos": "npm run build:ir-demos && node scripts/verify-ir.js ../examples/ir/demo1-stage-loop.ir.canonical.json ../examples/ir/demo1-stage-loop.ir.generated.json && node scripts/verify-ir.js ../examples/ir/demo2-event-recovery.ir.canonical.json ../examples/ir/demo2-event-recovery.ir.generated.json",
    "build:gmb-demos": "node scripts/mmlisp2mmb.js ../examples/ir/demo1-stage-loop.ir.canonical.json --out ../examples/gmb/demo1-stage-loop.mmb --meta ../examples/gmb/demo1-stage-loop.meta.json && node scripts/mmlisp2mmb.js ../examples/ir/demo2-event-recovery.ir.canonical.json --out ../examples/gmb/demo2-event-recovery.mmb --meta ../examples/gmb/demo2-event-recovery.meta.json",
    "check:gmb-demos": "npm run build:gmb-demos && node scripts/verify-mmb.js ../examples/gmb/demo1-stage-loop.mmb && node scripts/verify-mmb.js ../examples/gmb/demo2-event-recovery.mmb",
    "build:gmb-fixtures": "npm run build:gmb-demos && node scripts/make-mmb-fixtures.js",
    "check:gmb-fixtures": "npm run build:gmb-fixtures && node scripts/check-mmb-fixtures.js"
  },
  "engines": {
    "node": ">=18"
  }
}
