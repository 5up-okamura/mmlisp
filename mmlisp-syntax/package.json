{
  "name": "mmlisp-syntax",
  "displayName": "MMLisp Syntax",
  "description": "Syntax highlighting for MMLisp (.mmlisp) files",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "gml",
        "aliases": [
          "MMLisp"
        ],
        "extensions": [
          ".mmlisp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gml",
        "scopeName": "source.mmlisp",
        "path": "./syntaxes/gml.tmLanguage.json"
      }
    ]
  }
}
