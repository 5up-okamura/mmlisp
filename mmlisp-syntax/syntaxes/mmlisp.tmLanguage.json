{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "source.mmlisp",
  "name": "MMLisp",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#def-form" },
    { "include": "#defn-form" },
    { "include": "#structural-head" },
    { "include": "#note-head" },
    { "include": "#flow-head" },
    { "include": "#param-head" },
    { "include": "#label-decl" },
    { "include": "#voice-switch" },
    { "include": "#boolean" },
    { "include": "#keyword" },
    { "include": "#rest-shorthand" },
    { "include": "#fraction" },
    { "include": "#number" },
    { "include": "#paren" },
    { "include": "#bracket" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.semicolon.mmlisp",
      "match": ";.*$"
    },
    "string": {
      "name": "string.quoted.double.mmlisp",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.mmlisp",
          "match": "\\\\."
        }
      ]
    },
    "def-form": {
      "match": "(?<=\\()\\s*(def)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)",
      "captures": {
        "1": { "name": "storage.type.mmlisp" },
        "2": { "name": "variable.other.constant.mmlisp" }
      }
    },
    "defn-form": {
      "match": "(?<=\\()\\s*(defn)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)",
      "captures": {
        "1": { "name": "storage.type.mmlisp" },
        "2": { "name": "entity.name.function.definition.mmlisp" }
      }
    },
    "structural-head": {
      "match": "(?<=\\()\\s*(score|track)(?=[\\s)])",
      "captures": {
        "1": { "name": "keyword.control.mmlisp" }
      }
    },
    "note-head": {
      "match": "(?<=\\()\\s*(seq|rest|tie|tuplet)(?=[\\s)])",
      "captures": {
        "1": { "name": "entity.name.function.mmlisp" }
      }
    },
    "flow-head": {
      "match": "(?<=\\()\\s*(goto|x)(?=[\\s)])",
      "captures": {
        "1": { "name": "keyword.other.control-flow.mmlisp" }
      }
    },
    "param-head": {
      "match": "(?<=\\()\\s*(param-set|param-add)(?=[\\s)])",
      "captures": {
        "1": { "name": "support.function.mmlisp" }
      }
    },
    "label-decl": {
      "match": "(#)([a-zA-Z][a-zA-Z0-9_-]*)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.mmlisp" },
        "2": { "name": "entity.name.tag.mmlisp" }
      }
    },
    "voice-switch": {
      "match": "(@)([a-zA-Z][a-zA-Z0-9_-]*)",
      "captures": {
        "1": { "name": "punctuation.definition.variable.mmlisp" },
        "2": { "name": "variable.language.mmlisp" }
      }
    },
    "boolean": {
      "name": "constant.language.boolean.mmlisp",
      "match": "(?<=[\\s(])(?:true|false)(?=[\\s)])"
    },
    "keyword": {
      "name": "constant.other.keyword.mmlisp",
      "match": ":[a-zA-Z][a-zA-Z0-9_+-]*"
    },
    "rest-shorthand": {
      "name": "entity.name.function.mmlisp",
      "match": "(?<=\\s)_(?=[\\s)])"
    },
    "fraction": {
      "name": "constant.numeric.fraction.mmlisp",
      "match": "\\d+/\\d+"
    },
    "number": {
      "name": "constant.numeric.integer.mmlisp",
      "match": "(?<=[\\s(\\[])[+-]?\\d+(?=[\\s)\\]])"
    },
    "paren": {
      "name": "punctuation.section.parens.mmlisp",
      "match": "[()]"
    },
    "bracket": {
      "name": "punctuation.section.brackets.mmlisp",
      "match": "[\\[\\]]"
    }
  }
}
