; M2 "motion" stress — level fades (one-shot PARAM_SWEEP), a looping tremolo
; (loop PARAM_SWEEP, cancelled by the next note), PARAM_ADD accents, and a
; TEMPO_SWEEP ramp. Deliberately avoids NOTE_PITCH sweeps (glide/vibrato) —
; cent-interpolated pitch is the next increment.

(def pad :alg 4 :fb 2
  :ar1 24 :dr1 6 :sr1 1 :rr1 7 :sl1 2 :tl1 20 :ks1 0 :ml1 1 :dt1 0
  :ar2 28 :dr2 8 :sr2 2 :rr2 8 :sl2 3 :tl2 10 :ks2 0 :ml2 2 :dt2 1
  :ar3 26 :dr3 6 :sr3 1 :rr3 7 :sl3 2 :tl3 16 :ks3 0 :ml3 3 :dt3 -1
  :ar4 30 :dr4 9 :sr4 2 :rr4 9 :sl4 4 :tl4 4 :ks4 0 :ml4 1 :dt4 0)

; VOL fades: ease-out down, then a linear swell back up
(fm1 :tempo 120 pad :oct 4 :len 2 :vel 13
  c :vol (ease-out :from 31 :to 8 :len 90f) e
  g :vol (linear :from 8 :to 31 :len 60f) c)

; MASTER swell across the whole phrase (one-shot, spans notes)
(fm2 pad :oct 3 :len 1 :vel 12
  :master (ease-in :from 12 :to 31 :len 180f)
  c e g e)

; looping tremolo on VOL: a sine loop, re-triggered (cancelled) each note
(sqr1 :oct 5 :len 2 :vel 11
  e :vol (sin :from 20 :to 6 :len 20f) g
  b :vol (triangle :from 24 :to 10 :len 16f) e)

; PARAM_ADD accents via relative velocity, plus a tempo ramp
(sqr2 :oct 4 :len 4 :vel 8
  :tempo (linear :from 120 :to 168 :len 4)
  c :vel+ 4 e :vel+ -6 g :vel+ 4 c)
