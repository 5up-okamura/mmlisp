; M3 gate (slice 2): curve and loop-curve macros, pre-sampled at the :step
; clock into the same value-array shape the engine already steps. A one-shot
; eased envelope (attack, ends at key-off), a looping triangle LFO (sustain
; cycled), a multi-stage macro (attack curve → sustain loop), and MACRO_CLEAR.
(fm1 :tempo 150 :alg 4 :fb 3 :ar1 31 :tl1 20 :ar4 31 :tl4 8
  (macro :vol (ease-out 28..6 :len 8f)) :len 4
  c _
  (macro :vol (triangle 24..10 :len 6f :loop)) c e
  (macro :vol [(ease-in 20..28 :len 4f) (triangle 28..16 :len 6f :loop)]) g
  (macro :vol none) c)
